# Chave usada para assinar o cookie de sessão. OBRIGATÓRIA em produção.
# Sem ela (ou com valor fraco), qualquer pessoa pode forjar sessão e logar
# como qualquer usuário. O app se recusa a subir em produção sem isso setado.
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Diretório persistente do SQLite. Em produção (Render) aponte para o
# mount path de um Render Disk (ex.: /var/data). Em dev deixe em branco
# para usar ./data no próprio repo.
DATA_DIR=
UPLOAD_FOLDER=
